{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source = app.db"
  },

  "DocumentStorage": {
    "UploadPath": "App_Data/Uploads",
    "EncryptionKey": "",
    "AllowedExtensions": [ ".pdf", ".docx", ".xlsx" ],
    "MaxFileSizeBytes": 10485760,
    "MaxFilesPerClaim": 5
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
