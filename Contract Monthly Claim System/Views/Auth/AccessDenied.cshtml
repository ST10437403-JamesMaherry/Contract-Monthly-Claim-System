@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied - CMCS</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-card">
        <div class="auth-card-header">
            <p class="eyebrow mb-2">Access control</p>
            <h1 class="h3">Access Denied</h1>
        </div>

        <div class="auth-card-body text-center">
            <p class="text-muted mb-4">
                You do not have permission to access this page.
                @if (!string.IsNullOrEmpty(ViewBag.UserRole))
                {
                    <br />
                    <span class="mt-2 d-inline-block">
                        Your role: <strong>@ViewBag.UserRole</strong>
                    </span>
                }
            </p>

            <div class="d-grid gap-2">
                <a href="@Url.Action("Login", "Auth")" class="btn btn-primary">
                    Back to Login
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                    Go Back
                </a>
            </div>

            <div class="mt-4 pt-3 border-top">
                <small class="text-muted">
                    If you believe this is an error, please contact your system administrator.
                </small>
            </div>
        </div>
    </div>
</body>
</html>
