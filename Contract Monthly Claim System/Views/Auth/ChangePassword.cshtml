@{
    Layout = null;
    var mustChangePassword = ViewBag.MustChangePassword == true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password - CMCS</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-card">
        <div class="auth-card-header">
            <p class="eyebrow mb-2">Account security</p>
            <h1 class="h3">Change Password</h1>
            <p class="mb-0 mt-2">
                @(mustChangePassword ? "Your temporary password must be changed before you continue." : "Update your account password.")
            </p>
        </div>

        <div class="auth-card-body">
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    @TempData["Info"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Error:</strong> @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="post" asp-action="ChangePassword">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Current Password</label>
                    <input type="password" name="currentPassword" class="form-control" required autofocus />
                </div>

                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input type="password" name="newPassword" class="form-control" required minlength="6" />
                    <div class="form-text">Use at least 6 characters.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Confirm New Password</label>
                    <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
                </div>

                <button type="submit" class="btn btn-primary btn-login">
                    Update Password
                </button>
            </form>

            <form method="post" asp-action="Logout" class="mt-3">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary w-100">
                    Logout
                </button>
            </form>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
