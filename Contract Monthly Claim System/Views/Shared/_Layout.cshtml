@{
    var userRole = ViewBag.UserRole as string ?? string.Empty;
    var userName = Context.Session.GetString("UserName") ?? "User";
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    var hasRole = !string.IsNullOrWhiteSpace(userRole);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - CMCS</title>

    <!-- Bootstrap provides the reliable base layout and controls. -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

    <!-- jQuery is loaded before views because existing pages use it in sections. -->
    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-top fixed-top">
        <div class="container-fluid px-3 px-lg-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                <span class="brand-mark">CM</span>
                <span>CMCS</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                    @if (userRole == "Lecturer")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Dashboard", "Lecturer")">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("SubmitClaim", "Lecturer")">Submit Claim</a>
                        </li>
                    }
                    else if (userRole == "Coordinator")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ReviewClaims", "Coordinator")">Review Claims</a>
                        </li>
                    }
                    else if (userRole == "Manager")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ApproveClaims", "Manager")">Final Approvals</a>
                        </li>
                    }
                    else if (userRole == "HR")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("HRDashboard", "HR")">Manage Users</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("AddUser", "HR")">Add User</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("HRDashboard", "HR")#hrReports">Reports</a>
                        </li>
                    }

                    @if (hasRole)
                    {
                        <li class="nav-item user-menu ms-lg-3">
                            <span class="role-pill">@userRole</span>
                            <span class="user-name">@userName</span>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link logout-link">Logout</button>
                            </form>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="app-layout">
        @if (hasRole)
        {
            <aside class="sidebar">
                <div class="sidebar-header">
                    <div class="eyebrow">@userRole workspace</div>
                    <h2>Navigation</h2>
                </div>

                <ul class="nav flex-column sidebar-nav">
                    @if (userRole == "Lecturer")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Dashboard", "Lecturer")">Dashboard & Claims</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("SubmitClaim", "Lecturer")">Submit New Claim</a>
                        </li>
                    }
                    else if (userRole == "Coordinator")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ReviewClaims", "Coordinator")">Review Claims</a>
                        </li>
                    }
                    else if (userRole == "Manager")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ApproveClaims", "Manager")">Final Approvals</a>
                        </li>
                    }
                    else if (userRole == "HR")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("HRDashboard", "HR")">Manage Users</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("AddUser", "HR")">Add User</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("HRDashboard", "HR")#hrReports">Reports</a>
                        </li>
                    }
                </ul>

                <div class="sidebar-card">
                    <div class="eyebrow mb-2">Snapshot</div>
                    @if (userRole == "Lecturer")
                    {
                        <div class="metric-row"><span>Total Claims</span><strong>@(ViewBag.TotalClaims ?? 0)</strong></div>
                        <div class="metric-row"><span>Approved</span><strong>@(ViewBag.ApprovedClaims ?? 0)</strong></div>
                        <div class="metric-row"><span>Pending</span><strong>@(ViewBag.PendingClaims ?? 0)</strong></div>
                    }
                    else if (userRole == "Coordinator")
                    {
                        <div class="metric-row"><span>Pending Review</span><strong>@(ViewBag.PendingClaims ?? 0)</strong></div>
                        <div class="metric-row"><span>Approved Today</span><strong>@(ViewBag.ApprovedToday ?? 0)</strong></div>
                    }
                    else if (userRole == "Manager")
                    {
                        <div class="metric-row"><span>Pending Approval</span><strong>@(ViewBag.PendingClaims ?? 0)</strong></div>
                    }
                    else if (userRole == "HR")
                    {
                        <div class="metric-row"><span>Total Users</span><strong>@(ViewBag.TotalUsers ?? 0)</strong></div>
                    }
                </div>
            </aside>
        }

        <main class="main-content @(hasRole ? string.Empty : "main-content-full")">
            <div class="page-header">
                <div>
                    @if (hasRole)
                    {
                        <div class="eyebrow">@userRole</div>
                    }
                    <h1>@pageTitle</h1>
                </div>

                @if (userRole == "Lecturer" && pageTitle == "Submit Claim")
                {
                    <button class="btn btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#helpSection">
                        Help
                    </button>
                }
            </div>

            @if (userRole == "Lecturer" && pageTitle == "Submit Claim")
            {
                <div class="collapse mb-4" id="helpSection">
                    <div class="alert alert-info">
                        <h5>Claim Submission Guidelines</h5>
                        <ul class="mb-0">
                            <li>Your hourly rate is automatically pre-filled based on your contract.</li>
                            <li>Supported file formats are PDF, DOCX, and XLSX.</li>
                            <li>Ensure all supporting documents are clearly labeled.</li>
                            <li>Claims are processed within 3-5 business days.</li>
                        </ul>
                    </div>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
