@model List<Contract_Monthly_Claim_System.Models.User>

@{
    ViewData["Title"] = "HR Dashboard";
    var users = Model ?? new List<Contract_Monthly_Claim_System.Models.User>();
    var totalClaims = ViewBag.TotalClaims ?? 0;
    var approvedClaims = ViewBag.ApprovedClaims ?? 0;
    var pendingClaims = ViewBag.PendingClaims ?? 0;
    var totalUsers = users.Count;
    var payableClaims = ViewBag.PayableClaims as List<Claim> ?? new List<Claim>();
    var batchYear = ViewBag.CurrentBatchYear is int currentYear ? currentYear : DateTime.Now.Year;
    var batchMonth = ViewBag.CurrentBatchMonth is int currentMonth ? currentMonth : DateTime.Now.Month;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="dashboard-hero">
    <div class="hero-panel">
        <p class="eyebrow mb-2">People operations</p>
        <h2>Manage every system user from one focused workspace.</h2>
        <p>
            Search, filter, add, and update user profiles without leaving the HR dashboard.
        </p>
    </div>

    <div class="hero-kpi">
        <span>System users</span>
        <strong>@totalUsers</strong>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3 col-6">
        <div class="card stat-card text-center">
            <div class="card-body">
                <div class="stat-number">@totalUsers</div>
                <div class="stat-label">Users</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card text-center">
            <div class="card-body">
                <div class="stat-number">@totalClaims</div>
                <div class="stat-label">Claims</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card text-center card-approved">
            <div class="card-body">
                <div class="stat-number">@approvedClaims</div>
                <div class="stat-label">Approved</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card text-center card-pending">
            <div class="card-body">
                <div class="stat-number">@pendingClaims</div>
                <div class="stat-label">Pending</div>
            </div>
        </div>
    </div>
</div>

<div class="section-title">
    <div>
        <p class="eyebrow mb-1">Directory</p>
        <h2 class="h4">User Management</h2>
    </div>
    <a href="@Url.Action("AddUser", "HR")" class="btn btn-primary">Add New User</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-end g-3">
            <div class="col-lg-8">
                <label class="form-label">Filter Users by Role</label>
                <div class="btn-group" role="group" id="roleFilter">
                    <button type="button" class="btn btn-outline-secondary active" data-role="all">
                        All (@users.Count)
                    </button>
                    <button type="button" class="btn btn-outline-primary" data-role="Lecturer">
                        Lecturers (@users.Count(u => u.userRole == "Lecturer"))
                    </button>
                    <button type="button" class="btn btn-outline-success" data-role="Coordinator">
                        Coordinators (@users.Count(u => u.userRole == "Coordinator"))
                    </button>
                    <button type="button" class="btn btn-outline-info" data-role="Manager">
                        Managers (@users.Count(u => u.userRole == "Manager"))
                    </button>
                    <button type="button" class="btn btn-outline-danger" data-role="HR">
                        HR (@users.Count(u => u.userRole == "HR"))
                    </button>
                </div>
            </div>
            <div class="col-lg-4">
                <label class="form-label" for="searchInput">Search Users</label>
                <div class="input-group search-group ms-lg-auto">
                    <input type="text" class="form-control" placeholder="Name, email, or phone" id="searchInput">
                    <button class="btn btn-outline-secondary" type="button" id="clearSearch">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (!users.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"></div>
                <h5>No users found</h5>
                <p class="text-muted">Get started by adding your first user.</p>
                <a href="@Url.Action("AddUser", "HR")" class="btn btn-primary">Add First User</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="usersTable">
                    <thead>
                        <tr>
                            <th>User ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Hourly Rate</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            <tr data-role="@user.userRole" data-search="@(user.firstName + " " + user.lastName + " " + user.email + " " + user.phoneNumber)">
                                <td>@user.userId</td>
                                <td><strong>@user.firstName @user.lastName</strong></td>
                                <td>@user.email</td>
                                <td>@user.phoneNumber</td>
                                <td>
                                    <span class="badge @(user.userRole == "HR" ? "bg-danger" : user.userRole == "Manager" ? "bg-info" : user.userRole == "Coordinator" ? "bg-success" : "bg-primary")">
                                        @user.userRole
                                    </span>
                                </td>
                                <td>R @user.hourlyRate</td>
                                <td>
                                    <a href="@Url.Action("EditUser", "HR", new { id = user.userId })" class="btn btn-sm btn-outline-primary">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div id="noResults" class="empty-state">
                <div class="empty-state-icon"></div>
                <h5>No users match your filters</h5>
                <button class="btn btn-outline-secondary" id="resetFiltersFromEmpty">Reset Filters</button>
            </div>
        }
    </div>
</div>

<div class="section-title" id="hrReports">
    <div>
        <p class="eyebrow mb-1">Reports</p>
        <h2 class="h4">Export Reports</h2>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-lg-6">
        <div class="card h-100 card-approved">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Payment Processing Report</h5>
                <p class="card-text flex-grow-1">Download approved and paid claims for payroll processing.</p>
                <div class="d-grid gap-2 mt-auto">
                    <a href="@Url.Action("DownloadPaymentReportPdf", "HR")" class="btn btn-success">Download PDF</a>
                    <a href="@Url.Action("DownloadPaymentReportCsv", "HR")" class="btn btn-outline-success">Download CSV</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Monthly Payment Batch</h5>
                <p class="card-text">Export a payroll-ready CSV batch by payment month.</p>
                <form method="get" action="@Url.Action("DownloadMonthlyPaymentBatchCsv", "HR")" class="mt-auto">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label small">Year</label>
                            <input type="number" name="year" class="form-control" value="@batchYear" min="2020" max="2100" />
                        </div>
                        <div class="col-5">
                            <label class="form-label small">Month</label>
                            <input type="number" name="month" class="form-control" value="@batchMonth" min="1" max="12" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mt-3">Download Batch CSV</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card h-100 card-action">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">User Directory Report</h5>
                <p class="card-text flex-grow-1">Export the complete user directory for HR records.</p>
                <div class="d-grid gap-2 mt-auto">
                    <a href="@Url.Action("DownloadUserReportPdf", "HR")" class="btn btn-primary">Download PDF</a>
                    <a href="@Url.Action("DownloadUserReportCsv", "HR")" class="btn btn-outline-primary">Download CSV</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Claim Invoices</h5>
                <p class="card-text">Generate invoice PDFs for approved or paid claims.</p>
                @if (!payableClaims.Any())
                {
                    <p class="text-muted mb-0">No payable claims are ready for invoicing.</p>
                }
                else
                {
                    <div class="d-grid gap-2">
                        @foreach (var claim in payableClaims)
                        {
                            <a href="@Url.Action("DownloadInvoicePdf", "HR", new { claimId = claim.claimId })" class="btn btn-outline-primary">
                                Claim #@claim.claimId - R @claim.totalAmount.ToString("F2")
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Role Reports</h5>
                <p class="card-text">Export user directories by role.</p>
                <div class="row g-2">
                    @foreach (var role in new[] { "Lecturer", "Coordinator", "Manager", "HR" })
                    {
                        <div class="col-md-3">
                            <div class="d-grid gap-2">
                                <a href="@Url.Action("DownloadUserReportPdf", "HR", new { role })" class="btn btn-outline-primary">@role PDF</a>
                                <a href="@Url.Action("DownloadUserReportCsv", "HR", new { role })" class="btn btn-outline-secondary">@role CSV</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const roleFilter = document.getElementById('roleFilter');
            const searchInput = document.getElementById('searchInput');
            const clearSearch = document.getElementById('clearSearch');
            const resetFiltersFromEmpty = document.getElementById('resetFiltersFromEmpty');
            const usersTable = document.getElementById('usersTable');
            const noResults = document.getElementById('noResults');

            if (!usersTable) {
                return;
            }

            let currentRole = 'all';
            let currentSearch = '';

            function filterUsers() {
                const rows = usersTable.querySelectorAll('tbody tr');
                let visible = 0;

                rows.forEach(row => {
                    const roleMatch = currentRole === 'all' || row.dataset.role === currentRole;
                    const searchMatch = !currentSearch || row.dataset.search.toLowerCase().includes(currentSearch);

                    if (roleMatch && searchMatch) {
                        row.style.display = '';
                        visible++;
                    } else {
                        row.style.display = 'none';
                    }
                });

                noResults.style.display = visible === 0 ? 'block' : 'none';
                usersTable.style.display = visible === 0 ? 'none' : '';
            }

            if (roleFilter) {
                roleFilter.addEventListener('click', function (e) {
                    if (e.target.tagName === 'BUTTON' && e.target.dataset.role) {
                        roleFilter.querySelectorAll('button').forEach(function (button) {
                            button.classList.remove('active');
                        });
                        e.target.classList.add('active');
                        currentRole = e.target.dataset.role;
                        filterUsers();
                    }
                });
            }

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    currentSearch = searchInput.value.toLowerCase().trim();
                    filterUsers();
                });
            }

            if (clearSearch && searchInput) {
                clearSearch.addEventListener('click', function () {
                    searchInput.value = '';
                    currentSearch = '';
                    filterUsers();
                });
            }

            if (resetFiltersFromEmpty && roleFilter && searchInput) {
                resetFiltersFromEmpty.addEventListener('click', function () {
                    roleFilter.querySelectorAll('button').forEach(function (button) {
                        button.classList.remove('active');
                    });
                    roleFilter.querySelector('[data-role="all"]').classList.add('active');
                    searchInput.value = '';
                    currentRole = 'all';
                    currentSearch = '';
                    filterUsers();
                });
            }

            filterUsers();
        });
    </script>
}
